# CASCATA v1.0.0.0 - SOVEREIGN ORCHESTRATOR ENVIRONMENT
NODE_ENV=development

# Infrastructure
PORT=8080
DB_USER=cascata_admin
DB_PASS=cascata_secure_pillar_2026
DB_NAME=cascata_meta
LOG_LEVEL=info

# Storage
STORAGE_PATH=/tmp/cascata_storage

# Performance (Dragonfly)
DFLY_URL=redis://cascata-cache:6379

# Security Engine (Native AES-256)
