# CASCATA v1.0.0.0 - SOVEREIGN ORCHESTRATOR ENVIRONMENT
NODE_ENV=development

# Infrastructure
PORT=8080
DB_USER=cascata_admin
DB_PASS=cascata_vault_pillar_2026
DB_NAME=cascata_meta
LOG_LEVEL=info

# Storage
STORAGE_PATH=/tmp/cascata_storage

# Performance (Dragonfly)
DFLY_URL=redis://cascata-cache:6379

# Security (Vault)
VAULT_ADDR=http://cascata-vault:8200
VAULT_TOKEN=cascata_root_token

# Identity
SYSTEM_JWT_SECRET=cascata_system_default_secret_32_chars
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=cascata@example.com
