      "content": {
        "primary": "#0F172A",
        "secondary": "#475569",
        "muted": "#94A3B8",
        "inverse": "#F8FAFC"
      },
      "accent": {
        "primary": {
          "base": "#4F46E5",
          "hover": "#4338CA",
          "active": "#3730A3",
          "glow": "rgba(79,70,229,0.3)",
          "gradient": [ "#4F46E5", "#3730A3" ]
